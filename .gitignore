# f2a — .gitignore

# ── Rust ──
target/
**/*.rs.bk

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
*.so
*.pyd
*.pdb
python_test

# ── Virtual environments ──
.venv/
venv/
env/
f2a-old
uv.lock

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── OS ──
.DS_Store
Thumbs.db

# ── Test & Coverage ──
.pytest_cache/
htmlcov/
.coverage
coverage.xml
test_data_e2e/

# ── Output ──
output/*.html

# ── mypy / ruff ──
.mypy_cache/
.ruff_cache/
